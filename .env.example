# Copy this file to .env.local and fill in real values. Never commit real
# secrets — .env and .env.local are both gitignored.

# Supabase — public client config (safe in browser, protected by RLS).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only service role key (bypasses RLS). NEVER expose via NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Groq — server-only, never expose via NEXT_PUBLIC_*.
GROQ_API_KEY=
